<!DOCTYPE html>
<html lang="uk">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Графік — Квітень 2026 | beeжу</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #f5f5f0;
    --white: #ffffff;
    --surface2: #f0efe9;
    --border: #e5e4dd;
    --accent: #FF6B1A;
    --accent-light: rgba(255,107,26,0.08);
    --accent-mid: rgba(255,107,26,0.18);
    --green: #2db37c;
    --green-light: rgba(45,179,124,0.1);
    --yellow-light: rgba(245,166,35,0.1);
    --purple-light: rgba(124,92,252,0.1);
    --text: #1a1a18;
    --text2: #4a4a45;
    --muted: #9a9990;
    --card-radius: 16px;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { background: var(--bg); color: var(--text); font-family: 'Montserrat', sans-serif; min-height: 100vh; }

  header {
    background: var(--white);
    border-bottom: 2px solid var(--border);
    padding: 16px 24px 0;
    position: sticky; top: 0; z-index: 100;
    box-shadow: 0 2px 16px rgba(0,0,0,0.06);
  }
  .header-top {
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 12px; padding-bottom: 14px;
  }
  .logo {
    display: flex; align-items: center; gap: 10px;
    font-weight: 900; font-size: 18px; letter-spacing: -0.5px;
    color: var(--text); text-decoration: none;
  }
  .logo-bee {
    width: 34px; height: 34px; background: var(--accent);
    border-radius: 8px; display: flex; align-items: center;
    justify-content: center; font-size: 18px; flex-shrink: 0;
  }
  .logo-text span { color: var(--accent); }
  .header-meta { font-size: 12px; font-weight: 600; color: var(--muted); letter-spacing: 0.5px; text-transform: uppercase; }

  .search-wrap { position: relative; flex: 1; max-width: 300px; }
  .search-wrap input {
    width: 100%; background: var(--surface2); border: 2px solid var(--border);
    border-radius: 12px; padding: 9px 14px 9px 38px;
    color: var(--text); font-family: 'Montserrat', sans-serif;
    font-size: 13px; font-weight: 500; outline: none;
    transition: border-color 0.2s, background 0.2s;
  }
  .search-wrap input::placeholder { color: var(--muted); }
  .search-wrap input:focus { border-color: var(--accent); background: var(--white); }
  .search-icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--muted); font-size: 15px; pointer-events: none; }

  .days-nav {
    display: flex; gap: 0; overflow-x: auto;
    scrollbar-width: none; margin: 0 -24px; padding: 0 24px;
  }
  .days-nav::-webkit-scrollbar { display: none; }
  .day-pill {
    flex-shrink: 0; padding: 10px 14px 12px;
    font-family: 'Montserrat', sans-serif; font-size: 12px; font-weight: 700;
    cursor: pointer; border: none; background: transparent; color: var(--muted);
    transition: all 0.18s; white-space: nowrap;
    border-bottom: 3px solid transparent; position: relative; top: 2px; letter-spacing: 0.2px;
  }
  .day-pill:hover { color: var(--text); }
  .day-pill.active { color: var(--accent); border-bottom-color: var(--accent); }
  .day-pill.today { color: var(--green); }
  .day-pill.today.active { color: var(--green); border-bottom-color: var(--green); }

  main { padding: 28px 20px 80px; max-width: 860px; margin: 0 auto; }
  .day-block { display: none; }
  .day-block.visible { display: block; animation: fadeIn 0.2s ease; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }

  .day-header {
    display: flex; align-items: baseline; gap: 10px;
    margin-bottom: 20px; padding-bottom: 16px; border-bottom: 2px solid var(--border);
  }
  .day-date { font-size: 32px; font-weight: 900; line-height: 1; letter-spacing: -1px; }
  .day-weekday { font-size: 14px; color: var(--muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
  .jobs-count {
    margin-left: auto; font-size: 11px; font-weight: 700;
    background: var(--accent-light); border: 1.5px solid var(--accent-mid);
    padding: 4px 12px; border-radius: 20px; color: var(--accent);
    text-transform: uppercase; letter-spacing: 0.5px;
  }
  .today-badge {
    display: inline-block; background: var(--green); color: white;
    font-size: 10px; font-weight: 800; padding: 2px 7px; border-radius: 10px;
    letter-spacing: 0.5px; text-transform: uppercase; margin-left: 8px;
    vertical-align: middle; position: relative; top: -2px;
  }

  .job-card {
    background: var(--white); border: 1.5px solid var(--border);
    border-radius: var(--card-radius); padding: 16px 18px;
    margin-bottom: 10px; transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
    position: relative; overflow: hidden;
  }
  .job-card::before {
    content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 4px;
    background: var(--accent); border-radius: 4px 0 0 4px;
  }
  .job-card:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(0,0,0,0.1); border-color: rgba(255,107,26,0.25); }

  .job-top { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 8px; }
  .job-time {
    background: var(--accent-light); border: 1.5px solid var(--accent-mid);
    border-radius: 8px; padding: 5px 10px; font-size: 12px; font-weight: 800;
    color: var(--accent); white-space: nowrap; min-width: 72px; text-align: center;
    flex-shrink: 0; letter-spacing: 0.3px;
  }
  .job-time.no-time { color: var(--muted); background: var(--surface2); border-color: var(--border); }
  .job-address { font-weight: 800; font-size: 15px; line-height: 1.3; flex: 1; color: var(--text); }
  .job-type { font-size: 12.5px; color: var(--text2); margin-bottom: 10px; line-height: 1.5; font-weight: 500; padding-left: 84px; }
  .job-meta { display: flex; flex-wrap: wrap; gap: 6px; align-items: center; padding-left: 84px; }

  .meta-chip { display: inline-flex; align-items: center; gap: 4px; font-size: 11.5px; padding: 4px 10px; border-radius: 20px; font-weight: 600; }
  .chip-driver { background: rgba(255,107,26,0.08); color: #d45510; border: 1.5px solid rgba(255,107,26,0.2); }
  .chip-cleaners { background: var(--green-light); color: #1e9163; border: 1.5px solid rgba(45,179,124,0.2); }
  .chip-manager { background: var(--purple-light); color: #5e3fd4; border: 1.5px solid rgba(124,92,252,0.2); }
  .chip-note { background: var(--yellow-light); color: #b87810; border: 1.5px solid rgba(245,166,35,0.2); }

  .empty-state { text-align: center; padding: 60px 20px; color: var(--muted); }
  .empty-state .icon { font-size: 48px; margin-bottom: 12px; }
  .empty-state p { font-weight: 600; font-size: 14px; }
  .search-results { display: none; }
  .search-results.visible { display: block; }
  .search-header { font-weight: 800; font-size: 15px; margin-bottom: 20px; color: var(--text2); }
  .search-header span { color: var(--accent); }

  @media (max-width: 600px) {
    .day-date { font-size: 24px; }
    .header-meta { display: none; }
    .job-top { flex-direction: column; gap: 6px; }
    .job-time { min-width: unset; align-self: flex-start; }
    .job-type, .job-meta { padding-left: 0; }
  }
</style>
