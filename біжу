const TODAY = '28.04.2026';

function fmt(t) {
  if (!t) return '—';
  return t.replace(':00:00','').replace(':00','').trim() || '—';
}

function renderJobCard(job) {
  const t = fmt(job.time);
  const parts = [];
  if (job.driver) parts.push(`<span class="meta-chip chip-driver">🚗 ${job.driver}</span>`);
  if (job.manager) parts.push(`<span class="meta-chip chip-manager">👤 ${job.manager}</span>`);
  if (job.cleaners) parts.push(`<span class="meta-chip chip-cleaners">🧹 ${job.cleaners}</span>`);
  if (job.notes) parts.push(`<span class="meta-chip chip-note">📌 ${job.notes}</span>`);
  return `<div class="job-card">
    <div class="job-top">
      <span class="job-time ${t==='—'?'no-time':''}">${t}</span>
      <div class="job-address">${job.address}</div>
    </div>
    <div class="job-type">${job.type}</div>
    <div class="job-meta">${parts.join('')}</div>
  </div>`;
}

const nav = document.getElementById('daysNav');
SCHEDULE.forEach((day, i) => {
  const btn = document.createElement('button');
  const isToday = day.date === TODAY;
  btn.className = 'day-pill' + (isToday ? ' today' : '');
  btn.textContent = day.date.slice(0,5) + ' ' + day.weekday.slice(0,2);
  btn.onclick = () => showDay(i);
  nav.appendChild(btn);
});

const normalView = document.getElementById('normalView');
SCHEDULE.forEach((day, i) => {
  const block = document.createElement('div');
  block.className = 'day-block';
  block.id = 'day-' + i;
  const isToday = day.date === TODAY;
  const validJobs = day.jobs.filter(j => j.address && j.address !== '\\');
  block.innerHTML = `<div class="day-header">
    <span class="day-date">${day.date.slice(0,5)}</span>
    <span class="day-weekday">${day.weekday}${isToday ? '<span class="today-badge">Сьогодні</span>' : ''}</span>
    <span class="jobs-count">${validJobs.length} замовлень</span>
  </div>${validJobs.map(renderJobCard).join('')}`;
  normalView.appendChild(block);
});

const todayIdx = SCHEDULE.findIndex(d => d.date === TODAY);
showDay(todayIdx >= 0 ? todayIdx : 0);

function showDay(i) {
  document.querySelectorAll('.day-block').forEach(b => b.classList.remove('visible'));
  document.querySelectorAll('.day-pill').forEach(b => b.classList.remove('active'));
  document.getElementById('day-' + i).classList.add('visible');
  document.querySelectorAll('.day-pill')[i].classList.add('active');
  document.querySelectorAll('.day-pill')[i].scrollIntoView({behavior:'smooth', inline:'center', block:'nearest'});
  document.getElementById('searchResults').classList.remove('visible');
  document.getElementById('normalView').style.display = '';
  document.getElementById('searchInput').value = '';
}

function doSearch(q) {
  if (!q.trim()) {
    document.getElementById('searchResults').classList.remove('visible');
    document.getElementById('normalView').style.display = '';
    return;
  }
  const term = q.toLowerCase();
  document.getElementById('normalView').style.display = 'none';
  document.getElementById('searchResults').classList.add('visible');
  let html = '', total = 0;
  SCHEDULE.forEach(day => {
    const matches = day.jobs.filter(j =>
      j.address.toLowerCase().includes(term) ||
      (j.cleaners||'').toLowerCase().includes(term) ||
      (j.type||'').toLowerCase().includes(term) ||
      (j.driver||'').toLowerCase().includes(term) ||
      (j.notes||'').toLowerCase().includes(term)
    );
    if (matches.length) {
      total += matches.length;
      html += `<div style="margin-bottom:24px">
        <div style="font-size:11px;color:var(--muted);font-weight:700;margin-bottom:10px;padding-bottom:6px;border-bottom:1.5px solid var(--border);text-transform:uppercase;letter-spacing:0.8px">${day.date} — ${day.weekday}</div>
        ${matches.map(renderJobCard).join('')}
      </div>`;
    }
  });
  document.getElementById('searchHeader').innerHTML = `Знайдено: <span>${total} результатів</span> за запитом «${q}»`;
  document.getElementById('searchContent').innerHTML = html || '<div class="empty-state"><div class="icon">🔍</div><p>Нічого не знайдено</p></div>';
}
</script>
